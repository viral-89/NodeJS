<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Card | Card Generator</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <section class="w-full h-screen items-center justify-center flex flex-col">
      <div class="w-full flex flex-wrap items-center-justify-center gap-4 p-10">

        <% if(data.length > 0) { %>

        <% data.map((val) =>{ %>
        <div
          class="w-full max-w-sm rounded-xl border border-gray-200 bg-white p-6 shadow-sm"
        >
          <div class="flex items-center space-x-4">
            <img
              class="h-16 w-16 rounded-full object-cover ring-2 ring-gray-100"
              src="<%= val.image %>"
              alt="fname"
            />

            <div class="flex-1 min-width-0">
              <h2 class="text-lg font-bold text-gray-900 truncate"><%= val.fullname%></h2>
              <p class="text-sm text-gray-500 font-medium"><%= val.username%></p>
            </div>
          </div>

          <div class="mt-4">
            <p class="text-sm text-gray-600 truncate"><%= val.email%></p>
          </div>

          <div class="mt-6 flex gap-3">
            <a href="/show/<%= val._id %>" class="flex-1 text-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 transition-colors">
              <button>
              Edit
            </button>
            </a>
            <a href="/delete/<%= val._id %>" class="flex-1 text-center rounded-md border border-red-200 bg-white px-3 py-2 text-sm font-semibold text-red-600 hover:bg-red-50 transition-colors">
              <button>
              Delete
            </button>
            </a>
          </div>
        </div>

       <% })%>

     <% } else { %>
      <h1 class="text-center text-3xl text-gray-300 font-semibold">No Card Here. Create A Card First</h1>
     <% } %>
   
      </div>

      <a
        href="/"
        class="px-4 py-2 bg-blue-600 rounded-xl active:bg-blue-100 active:scale-95"
      >
        <button class="border-none">Go to Homepage</button>
      </a>
    </section>
  </body>
</html>
